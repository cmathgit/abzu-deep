# =============================================================================
# Input / Output Limits
# MAX_INPUT_LENGTH  — character cap applied to incoming user text before LLM call
# MAX_OUTPUT_TOKENS — token limit passed as a parameter in the LLM prompt request
# =============================================================================
MAX_INPUT_LENGTH=1024
MAX_OUTPUT_TOKENS=4096

# =============================================================================
# Telegram Polling Configuration
# POLL_TIMEOUT  — long-poll hold duration in seconds.
#                 Telegram server holds the connection open for this duration
#                 before returning an empty result if no messages arrive.
#                 Recommended: 20–30. Set to 0 only for debugging (short poll).
# POLL_INTERVAL — sleep duration in seconds between poll cycles.
#                 Used for error recovery backoff. Not used during normal long polling.
# =============================================================================
POLL_TIMEOUT=30
POLL_INTERVAL=1

# =============================================================================
# Context Window Management
# MAX_CONTEXT_MESSAGES — number of prior messages retained per chat_id in memory.
#                        Managed inside each serve-*.py script, not in telegram-api.py.
# =============================================================================
MAX_CONTEXT_MESSAGES=5

