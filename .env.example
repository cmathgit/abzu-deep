# =============================================================================
# Telegram Bot Tokens
# Generate each token via @BotFather on Telegram.
# Each serve-*.py script loads its assigned token by name.
# =============================================================================
TELEGRAM_BOT_TOKEN_OLLAMA=your_ollama_bot_token_here
TELEGRAM_BOT_TOKEN_GEMINI=your_gemini_bot_token_here
TELEGRAM_BOT_TOKEN_COHERE=your_cohere_bot_token_here
TELEGRAM_BOT_TOKEN_MISTRAL=your_mistral_bot_token_here
